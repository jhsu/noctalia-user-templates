				<key>wordHighlight</key>
				<string>{{colors.on_surface_variant.default.hex | set_alpha 0.2}}</string>
				<key>wordHighlightStrong</key>
				<string>{{colors.primary.default.hex | set_alpha 0.24}}</string>

