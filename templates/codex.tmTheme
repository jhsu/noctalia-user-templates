				<string>{{colors.tertiary.default.hex | set_alpha 0.28}}</string>

				<key>hoverHighlight</key>
				<string>{{colors.primary.default.hex | set_alpha 0.24}}</string>

				<key>referenceHighlight</key>
				<string>{{colors.secondary.default.hex | set_alpha 0.3}}</string>

