{
  "$schema": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
  "name": "NoctaliaTheme",
  "vars": {
    "primary": "{{colors.primary.default.hex}}",
    "on_primary": "{{colors.on_primary.default.hex}}",
    "primary_container": "{{colors.primary_container.default.hex}}",
    "secondary": "{{colors.secondary.default.hex}}",
    "on_secondary": "{{colors.on_secondary.default.hex}}",
    "secondary_container": "{{colors.secondary_container.default.hex}}",
    "tertiary": "{{colors.tertiary.default.hex}}",
    "on_tertiary": "{{colors.on_tertiary.default.hex}}",
    "error": "{{colors.error.default.hex}}",
    "on_error": "{{colors.on_error.default.hex}}",
    "error_container": "{{colors.error_container.default.hex}}",
    "surface": "{{colors.surface.default.hex}}",
    "surface_variant": "{{colors.surface_variant.default.hex}}",
    "surface_container_low": "{{colors.surface_container_low.default.hex}}",
    "surface_container": "{{colors.surface_container.default.hex}}",
    "surface_container_high": "{{colors.surface_container_high.default.hex}}",
    "on_surface": "{{colors.on_surface.default.hex}}",
    "on_surface_variant": "{{colors.on_surface_variant.default.hex}}",
    "outline": "{{colors.outline.default.hex}}",
    "outline_variant": "{{colors.outline_variant.default.hex}}",
    "inverse_primary": "{{colors.inverse_primary.default.hex}}",
    "primary_soft": "{{colors.primary.default.hex | set_alpha 0.2}}",
    "secondary_soft": "{{colors.secondary.default.hex | set_alpha 0.2}}",
    "error_soft": "{{colors.error.default.hex | set_alpha 0.2}}",
    "surface_dim": "{{colors.surface.default.hex | darken 6}}",
    "surface_bright": "{{colors.surface.default.hex | lighten 6}}",
    "outline_soft": "{{colors.outline.default.hex | set_alpha 0.6}}",
    "on_surface_muted": "{{colors.on_surface.default.hex | set_alpha 0.75}}"
  },
  "colors": {
    "accent": "primary",
    "border": "outline",
    "borderAccent": "primary",
    "borderMuted": "outline_soft",
    "success": "secondary",
    "error": "error",
    "warning": "tertiary",
    "muted": "on_surface_muted",
    "dim": "surface_dim",
    "text": "on_surface",
    "thinkingText": "on_surface_variant",
    "selectedBg": "surface_bright",
    "userMessageBg": "surface_container",
    "userMessageText": "on_surface",
    "customMessageBg": "surface_container_high",
    "customMessageText": "on_surface",
    "customMessageLabel": "primary",
    "toolPendingBg": "surface_dim",
    "toolSuccessBg": "secondary_soft",
    "toolErrorBg": "error_soft",
    "toolTitle": "primary",
    "toolOutput": "on_surface",
    "mdHeading": "primary",
    "mdLink": "primary",
    "mdLinkUrl": "secondary",
    "mdCode": "tertiary",
    "mdCodeBlock": "on_surface",
    "mdCodeBlockBorder": "outline_soft",
    "mdQuote": "on_surface_variant",
    "mdQuoteBorder": "outline",
    "mdHr": "outline_variant",
    "mdListBullet": "tertiary",
    "toolDiffAdded": "secondary",
    "toolDiffRemoved": "error",
    "toolDiffContext": "on_surface_variant",
    "syntaxComment": "on_surface_variant",
    "syntaxKeyword": "primary",
    "syntaxFunction": "secondary",
    "syntaxVariable": "on_surface",
    "syntaxString": "tertiary",
    "syntaxNumber": "tertiary",
    "syntaxType": "secondary",
    "syntaxOperator": "on_surface",
    "syntaxPunctuation": "on_surface_variant",
    "thinkingOff": "on_surface_variant",
    "thinkingMinimal": "primary",
    "thinkingLow": "secondary",
    "thinkingMedium": "tertiary",
    "thinkingHigh": "error",
    "thinkingXhigh": "inverse_primary",
    "bashMode": "primary"
  }
}
